{
  "expo": {
    "name": "TechBite",
    "slug": "techbite",
    "version": "1.0.0",
    "description": "Daily bite-sized technical news and interview preparation tips for CS students and developers. Powered by AI for precision and clarity.",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/app_icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "backgroundColor": "#0F172A",
    "primaryColor": "#7C3AED",
    "scheme": "techbite",
    "splash": {
      "image": "./assets/app_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.techbite.app",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "TechBite does not use the camera.",
        "NSPhotoLibraryUsageDescription": "TechBite does not access your photos."
      }
    },
    "android": {
      "package": "com.techbite.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app_icon.png",
        "backgroundColor": "#0F172A"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "techbite",
              "host": "bite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/app_icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 29,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b983c33c-0335-471b-9fe4-f7e2ff6b263f"
      }
    },
    "owner": "karanchaudhari04"
  }
}
