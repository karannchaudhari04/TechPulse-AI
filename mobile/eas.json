{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://techbite.onrender.com/api/v1",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "USE_EAS_SECRETS_OR_ENV",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "techbite-2ad11",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "USE_EAS_SECRETS_OR_ENV",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "USE_EAS_SECRETS_OR_ENV"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://techbite.onrender.com/api/v1",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "USE_EAS_SECRETS_OR_ENV",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "techbite-2ad11",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "USE_EAS_SECRETS_OR_ENV",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "USE_EAS_SECRETS_OR_ENV"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
